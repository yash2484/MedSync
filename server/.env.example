# Copy to .env for local-without-Docker runs and adjust hostnames to localhost.
APP_ENV=dev
DATABASE_URL=postgresql+asyncpg://medsync:medsync@localhost:5432/medsync
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
EMBEDDING_PROVIDER=local
